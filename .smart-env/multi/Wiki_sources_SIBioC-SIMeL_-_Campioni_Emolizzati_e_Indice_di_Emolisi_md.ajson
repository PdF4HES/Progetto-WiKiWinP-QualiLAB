04174954,-0.02316104,0.01985554,0.00940721,0.04910284,0.02360166,0.00927377,-0.00557519,0.04879013,-0.02245867,0.03655415,-0.05986174,-0.05113894,-0.01541713,0.13660972,0.00659317,-0.07336638,0.02775895,-0.01953857,0.04454207,-0.00761263,0.0209552,0.01281144,-0.00294746,0.10801318,0.0063262,0.00520331,0.03055636,-0.00242648,-0.01251446,0.03280887,-0.01189155,-0.04175339,0.03546728,-0.0699734,0.00654128,0.06802961,-0.02901602,0.01373563,-0.01310696,0.00436745,0.04495934,-0.03182708,-0.02729682,-0.05759267,0.04190318,0.02369808,-0.00305686,0.02173106,0.01977437,-0.06970763,-0.00806026,-0.00967062,0.01097423,-0.03522333,0.0644734,0.02533952],"last_embed":{"tokens":464,"hash":"1wd2cpm"}}},"last_read":{"hash":"1wd2cpm","at":1781675971214},"class_name":"SmartSource","last_import":{"mtime":1781327040000,"size":6292,"at":1781675837115,"hash":"1wd2cpm"},"blocks":{"#---frontmatter---":[1,36],"##Sintesi":[38,41],"##Sintesi#{1}":[40,41],"##Fisiopatologia ed emolisi in vitro vs in vivo":[42,45],"##Fisiopatologia ed emolisi in vitro vs in vivo#{1}":[44,45],"##L'indice di emolisi (H-index)":[46,49],"##L'indice di emolisi (H-index)#{1}":[48,49],"##Raccomandazioni operative":[50,53],"##Raccomandazioni operative#{1}":[52,53]},"outlinks":[{"title":"SIPMeL","target":"SIPMeL","line":18},{"title":"Gruppo di Studio Variabilità Extra-Analitica (GdS VEA) SIPMeL","target":"Gruppo di Studio Variabilità Extra-Analitica (GdS VEA) SIPMeL","line":19},{"title":"Interferenze Endogene HIL (Emolisi, Ittero, Lipemia)","target":"Interferenze Endogene HIL (Emolisi, Ittero, Lipemia)","line":20},{"title":"SIPMeL - Interferenza da Lipemia","target":"SIPMeL - Interferenza da Lipemia","line":21},{"title":"SIPMeL - Interferenza da Ittero","target":"SIPMeL - Interferenza da Ittero","line":22},{"title":"Falsi Positivi e Falsi Negativi in Diagnostica di Laboratorio","target":"Falsi Positivi e Falsi Negativi in Diagnostica di Laboratorio","line":23},{"title":"Fase Preanalitica","target":"Fase Preanalitica","line":24},{"title":"Flebotomia e Prelievo Venoso","target":"Flebotomia e Prelievo Venoso","line":25},{"title":"ISO 15189","target":"ISO 15189","line":26},{"title":"GdS VEA SIPMeL","target":"Gruppo di Studio Variabilità Extra-Analitica (GdS VEA) SIPMeL","line":40},{"title":"SIPMeL","target":"SIPMeL","line":40},{"title":"SIPMeL - Interferenza da Ittero","target":"SIPMeL - Interferenza da Ittero","line":40},{"title":"SIPMeL - Interferenza da Lipemia","target":"SIPMeL - Interferenza da Lipemia","line":40},{"title":"Flebotomia e Prelievo Venoso","target":"Flebotomia e Prelievo Venoso","line":52},{"title":"SIPMeL - Checklist per il Prelievo di Sangue Venoso","target":"SIPMeL - Checklist per il Prelievo di Sangue Venoso","line":52}],"metadata":{"type":"source","title":"SIBioC-SIMeL - Campioni Emolizzati e Indice di Emolisi","created":"2026-06-13","updated":"2026-06-13","tags":["#laboratorio-medico","#source","#sipmel","#interferenze-analitiche","#fase-preanalitica"],"status":"developing","address":"c-000093","source_type":"guideline","author":"Giuseppe Lippi et al., per il Gruppo di Studio Intersocietario SIBioC-SIMeL-CISMEL sulla Variabilità Extra-Analitica del Dato di Laboratorio","publication":"Riv Ital Med Lab (Biochim Clin), manoscritto RIME-D-11-00019, Raccomandazioni di consenso SIBioC-SIMeL per la rilevazione e gestione dei campioni emolizzati e utilizzo dell'indice di emolisi","related":["[[SIPMeL]]","[[Gruppo di Studio Variabilità Extra-Analitica (GdS VEA) SIPMeL]]","[[Interferenze Endogene HIL (Emolisi, Ittero, Lipemia)]]","[[SIPMeL - Interferenza da Lipemia]]","[[SIPMeL - Interferenza da Ittero]]","[[Falsi Positivi e Falsi Negativi in Diagnostica di Laboratorio]]","[[Fase Preanalitica]]","[[Flebotomia e Prelievo Venoso]]","[[ISO 15189]]"],"key_claims":["L'emolisi in vitro è la causa di gran lunga più frequente di non idoneità dei campioni biologici (40-70% di tutte le non conformità), con prevalenza vicina al 3% di tutti i campioni di routine, fino a >10% nei campioni provenienti da pronto soccorso e pediatria.","L'emolisi è oggettivata dalla concentrazione di emoglobina libera: limite superiore di riferimento 20 mg/L in plasma e 50 mg/L in siero; diventa visivamente evidente sopra 300 mg/L (lieve <300, modesta 300-600, elevata >600 mg/L).","Il metodo raccomandato per la quantificazione è la determinazione automatizzata dell'indice di emolisi (H-index) sugli analizzatori di chimica clinica, basata su letture spettrofotometriche tra 340 e 670 nm (picchi utili a 414, 540 e 570 nm per l'emoglobina libera).","L'emolisi interferisce con tre meccanismi principali: rilascio di analiti ad alta concentrazione intraeritrocitaria (potassio, LDH, AST, GGT), effetto di diluizione per analiti poco rappresentati nel globulo rosso (sodio, cloro, albumina), e interferenza spettrofotometrica/chimica diretta (bilirubina, CK, troponine, test coagulativi per rilascio di sostanze tromboplastiniche).","L'emolisi in vitro va distinta dall'emolisi in vivo (anemia emolitica, ~5% di tutte le anemie): l'aptoglobina plasmatica ridotta è il marcatore più affidabile di emolisi intravascolare, perché non è influenzata dall'emolisi avvenuta dopo il prelievo.","Le cause di emolisi in vitro coprono tutta la catena preanalitica: caratteristiche del paziente (vene fragili), abilità dell'operatore, dispositivo di prelievo (aghi <23G, agocannule, laccio prolungato), trattamento immediato del campione (miscelazione eccessiva o insufficiente), trasporto e centrifugazione.","Gestione raccomandata dei campioni emolizzati: (i) notifica immediata al reparto secondo modalità locali; (ii) soppressione di tutti i test influenzati dal grado di emolisi osservato, riferendosi a tabelle di interferenza per analita o a soglie definite localmente sulla base della variabilità biologica; (iii) richiesta tempestiva di un secondo campione per ripetere i test soppressi.","Per i sistemi 'chiusi' (preanalitica in catena con l'analitica, senza possibilità di ispezione visiva del campione centrifugato) la determinazione dell'indice di emolisi su tutti i campioni è raccomandazione di grado A; per i sistemi 'aperti' è invece raccomandata un'ispezione visiva preliminare seguita da H-index sui campioni sospetti."]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"key":"Wiki/sources/SIBioC-SIMeL - Campioni Emolizzati e Indice di Emolisi.md"},
