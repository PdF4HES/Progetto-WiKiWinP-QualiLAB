74,-0.00825059,-0.05470631,0.00567472,-0.00971717,0.03036176,-0.00601908,-0.00521439,0.00271361,0.03903116,0.06274956,-0.04289337,-0.00476337,0.00943858,0.17282601,-0.01115302,-0.03329431,0.0394118,-0.00551817,0.04172601,0.0643462,0.04613826,-0.02456466,-0.01723627,0.11663976,-0.02125209,-0.01526666,0.09013892,-0.04211145,0.02736534,0.01893054,0.0054427,-0.08455186,-0.00431023,-0.03290344,0.00960626,0.09581012,-0.06675794,-0.05054186,-0.04545773,0.02251501,0.09018183,-0.00915205,0.02127984,-0.02591594,0.02405911,-0.00387184,0.01929839,0.00003128,-0.00747557,-0.06525921,0.03279155,-0.04183196,0.04905646,0.00984185,0.0614484,0.03716413],"last_embed":{"tokens":461,"hash":"mmi3kp"}}},"last_read":{"hash":"mmi3kp","at":1781675950928},"class_name":"SmartSource","last_import":{"mtime":1781283488000,"size":4889,"at":1781675837061,"hash":"mmi3kp"},"blocks":{"#---frontmatter---":[1,38],"##Cosa è":[40,43],"##Cosa è#{1}":[42,43],"##Struttura prescritta per ogni SOP":[44,56],"##Struttura prescritta per ogni SOP#{1}":[46,47],"##Struttura prescritta per ogni SOP#{2}":[48,48],"##Struttura prescritta per ogni SOP#{3}":[49,49],"##Struttura prescritta per ogni SOP#{4}":[50,50],"##Struttura prescritta per ogni SOP#{5}":[51,51],"##Struttura prescritta per ogni SOP#{6}":[52,52],"##Struttura prescritta per ogni SOP#{7}":[53,53],"##Struttura prescritta per ogni SOP#{8}":[54,54],"##Struttura prescritta per ogni SOP#{9}":[55,56],"##Come operazionalizza ISO 15189":[57,60],"##Come operazionalizza ISO 15189#{1}":[59,60]},"outlinks":[{"title":"ISO 15189","target":"ISO 15189","line":28},{"title":"Sistema di Gestione per la Qualità","target":"Sistema di Gestione per la Qualità","line":29},{"title":"Processo di Accreditamento","target":"Processo di Accreditamento","line":30},{"title":"SOP Controllo Valori Critici","target":"SOP Controllo Valori Critici","line":31},{"title":"SOP Tabella Valori Critici (Esempio)","target":"SOP Tabella Valori Critici (Esempio)","line":32},{"title":"SOP Piano di Addestramento e Formazione","target":"SOP Piano di Addestramento e Formazione","line":33},{"title":"Valori Critici","target":"Valori Critici","line":34},{"title":"Competenza e Formazione del Personale","target":"Competenza e Formazione del Personale","line":35},{"title":".raw/Procedura Operativa Standard ISO 15189.docx","target":".raw/Procedura Operativa Standard ISO 15189.docx","line":37},{"title":"ISO 15189","target":"ISO 15189","line":42},{"title":"Processo di Accreditamento","target":"Processo di Accreditamento","line":59},{"title":"Sistema di Gestione per la Qualità","target":"Sistema di Gestione per la Qualità","line":59},{"title":"SOP Controllo Valori Critici","target":"SOP Controllo Valori Critici","line":59},{"title":"SOP Piano di Addestramento e Formazione","target":"SOP Piano di Addestramento e Formazione","line":59}],"metadata":{"type":"source","title":"Procedura Operativa Standard ISO 15189 (SOP Master)","created":"2026-06-12","updated":"2026-06-12","tags":["#laboratorio-medico","#source","#normativa","#sgq"],"status":"developing","address":"c-000016","source_type":"internal-document","author":"","date_published":"2026-06-12","url":"","confidence":"high","key_claims":["Una SOP conforme a ISO 15189 deve essere un documento ingegnerizzato che dimostra il controllo del rischio e garantisce la riproducibilità del processo indipendentemente dall'operatore.","Ogni SOP apre con un'intestazione di controllo documento: logo/nome laboratorio, titolo, codice univoco e numero di revisione, data di entrata in vigore, paginazione 'Pagina X di Y', e tre firme (Redatto da, Verificato da, Approvato da).","La sezione Scopo e Campo di Applicazione definisce l'obiettivo di qualità del documento e i confini operativi (dove, quando, su quali campioni si applica).","La sezione Responsabilità assegna in modo tassativo i compiti alle figure professionali coinvolte (Medico, Biologo, TSLB, Infermiere).","La Gestione del Rischio Clinico è il cuore dell'impostazione ISO 15189: ogni SOP deve identificare cosa può andare storto e le azioni di mitigazione attive.","La Descrizione delle Attività segue lo schema delle tre fasi del processo analitico: pre-analitica, analitica (incluso il CQI e le regole di Westgard) e post-analitica (validazione, refertazione, gestione dei valori critici).","Ogni SOP elenca i Riferimenti Normativi e Bibliografici (clausole ISO 15189, linee guida SIBioC/SIPMeL/CLSI, manuali del fabbricante) e la Modulistica e Registrazioni che produce come evidenza oggettiva.","Lo Storico delle Revisioni in coda al documento traccia numero di revisione precedente e attuale, data della modifica e descrizione del cambiamento."],"related":["[[ISO 15189]]","[[Sistema di Gestione per la Qualità]]","[[Processo di Accreditamento]]","[[SOP Controllo Valori Critici]]","[[SOP Tabella Valori Critici (Esempio)]]","[[SOP Piano di Addestramento e Formazione]]","[[Valori Critici]]","[[Competenza e Formazione del Personale]]"],"sources":["[[.raw/Procedura Operativa Standard ISO 15189.docx]]"]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"key":"Wiki/sources/Procedura Operativa Standard ISO 15189 (SOP Master).md"},
