7,0.00553773,-0.03194518,-0.04250125,-0.03166997,-0.00970447,-0.00785433,0.00325084,0.04170261,-0.02319189,0.01043093,0.00584675,-0.02370726,0.0750198,-0.06849822,-0.02366789,0.02748303,0.1759897,-0.0483273,0.00210676,0.07407572,-0.00114499,0.0033563,0.00774748,0.04756108,0.03505946,-0.0389357,0.10648417,-0.01564283,-0.03929212,0.06718657,-0.03916195,0.01606317,0.00858206,-0.05366711,-0.03199519,0.01761481,-0.05225992,-0.01029844,0.03882014,-0.00025916,-0.09132562,-0.02802583,-0.03733085,0.07583351,-0.04806527,-0.07260925,0.02821796,0.02341727,-0.02372416,0.02563619,0.04312392,-0.02315878,-0.05794102,0.00325922,0.00724471,0.07166399,-0.02297912,0.09872945,0.04938569],"last_embed":{"tokens":456,"hash":"1wyrcdb"}}},"last_read":{"hash":"1wyrcdb","at":1781675976701},"class_name":"SmartSource","last_import":{"mtime":1781338772000,"size":5292,"at":1781675837115,"hash":"1wyrcdb"},"blocks":{"#---frontmatter---":[1,38],"##Sintesi":[40,43],"##Sintesi#{1}":[42,43],"##Basi metodologiche":[44,47],"##Basi metodologiche#{1}":[46,47],"##Indicazioni cliniche per area":[48,57],"##Indicazioni cliniche per area#{1}":[50,51],"##Indicazioni cliniche per area#{2}":[52,52],"##Indicazioni cliniche per area#{3}":[53,53],"##Indicazioni cliniche per area#{4}":[54,54],"##Indicazioni cliniche per area#{5}":[55,55],"##Indicazioni cliniche per area#{6}":[56,57],"##Posizionamento diagnostico":[58,61],"##Posizionamento diagnostico#{1}":[60,61]},"outlinks":[{"title":"SIPMeL","target":"SIPMeL","line":24},{"title":"Gruppo di Studio Allergologia SIPMeL","target":"Gruppo di Studio Allergologia SIPMeL","line":25},{"title":"Diagnostica di Laboratorio in Allergologia","target":"Diagnostica di Laboratorio in Allergologia","line":26},{"title":"Validazione e Verifica dei Metodi Analitici","target":"Validazione e Verifica dei Metodi Analitici","line":27},{"title":"Falsi Positivi e Falsi Negativi in Diagnostica di Laboratorio","target":"Falsi Positivi e Falsi Negativi in Diagnostica di Laboratorio","line":28},{"title":"Gruppo di Studio in Allergologia","target":"Gruppo di Studio Allergologia SIPMeL","line":42}],"metadata":{"type":"source","title":"SIPMeL - Test di Attivazione dei Basofili (BAT) in Allergologia","created":"2026-06-13","updated":"2026-06-13","tags":["#laboratorio-medico","#source","#allergologia","#sipmel","#citofluorimetria"],"status":"developing","address":"c-000114","source_type":"guideline","authors":["Ignazio Brusca","Nicola Bizzaro","Giampaola Pesce","Laura Caponi","Beatrice Caruso","Danilo Villalta"],"publication":"La Rivista Italiana della Medicina di Laboratorio (Riv Ital Med Lab), 2015","related":["[[SIPMeL]]","[[Gruppo di Studio Allergologia SIPMeL]]","[[Diagnostica di Laboratorio in Allergologia]]","[[Validazione e Verifica dei Metodi Analitici]]","[[Falsi Positivi e Falsi Negativi in Diagnostica di Laboratorio]]"],"key_claims":["Il BAT simula in vitro un test di scatenamento allergenico in vivo, misurando tramite citofluorimetria l'espressione di marcatori di attivazione (CD63, CD203c) sui basofili dopo incubazione con l'allergene.","Il BAT è un ausilio diagnostico di terzo livello, da riservare a centri con competenze specialistiche di allergologia e immunologia di base, non per uso indiscriminato in tutti i laboratori.","Nell'allergia al lattice il BAT mostra sensibilità 79,5-100% e specificità 97-100%, utile in particolare per identificare soggetti allergici negativi ai test classici (skin prick test, IgE specifiche).","Nell'allergia al veleno di imenotteri il BAT (sensibilità 70-100%, specificità 85-100%) è indicato nei casi di dubbio diagnostico sull'insetto responsabile e nel monitoraggio dell'immunoterapia specifica (ITS), ma può essere confuso da sensibilizzazione a carboidrati cross-reattivi (CCD).","Nelle allergie alimentari il BAT può ridurre il ricorso al challenge in doppio cieco con placebo: in pazienti allergici all'arachide raggiunge un'area sotto la curva ROC di 0,96-0,97, e in allergici al latte un valore predittivo negativo del 96%.","Nelle allergie a farmaci (FANS, beta-lattamici, miorilassanti) il BAT ha sensibilità non elevata ma buona specificità: è utile per confermare un sospetto diagnostico ma non per escludere una sensibilizzazione.","Per i FANS e i beta-lattamici è preferibile testare un pannello di farmaci della stessa classe, con almeno due diluizioni, piuttosto che un singolo farmaco sospetto.","Il marcatore CD203c non richiede priming con IL-3 (a differenza di CD63), è espresso solo su basofili e mastociti e non compare ex-novo dopo attivazione, ma viene sovra-espresso."]},"task_lines":[],"tasks":{},"codeblock_ranges":[]},"smart_blocks:Wiki/sources/SIPMeL - Test di Attivazione dei Basofili (BAT) in Allergologia.md#---frontmatter---": {"path":null,"last_embed":{"hash":"vxclli","at":1781675976482},"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.10090885,0.07653056,-0.03322321,0.04906668,-0.02380151,-0.05964937,0.03403948,0.06387813,-0.05476183,-0.00301257,-0.05997547,-0.11198226,-0.05079413,0.05016082,0.01642044,-0.00412711,0.00023449,-0.02999974,0.00346432,-0.01492896,0.13509355,-0.0430228,0.00324627,-0.04480236,0.06496805,0.05111126,0.03993078,-0.01966154,-0.04357235,-0.19741805,0.03005832,-0.01499365,0.04997698,-0.03709331,0.02599187,0.06171461,-0.01388482,0.04285872,0.02644579,0.03315537,0.06855146,0.06967707,-0.01435229,0.01011576,-0.05962843,-0.03138067,0.02540958,0.02034099,-0.01186499,-0.0318752,-0.05697561,-0.01202757,-0.00675129,0.00973482,-0.0704212,0.03499655,0.01210461,-0.01404633,0.03420963,0.04023406,0.05306735,0.05317471,-0.2492435,0.07755186,0.02184735,0.02928746,-0.05354163,-0.03402679,0.03856818,0.04087554,-0.0241641,0.00734903,0.07641511,0.04394078,0.04021145,0.045106,-0.0266056,-0.01066975,-0.01100674,0.01465685,0.00852016,0.01255055,-0.04079243,-0.05443942,0.00799808,0.0055447,-0.02332031,0.03035967,-0.00731197,0.0164248,-0.01961901,-0.03416372,0.02941142,0.0680721,-0.02882583,-0.00074866,-0.03186235,-0.01483352,-0.01779019,0.11036555,-0.05185194,-0.0300