5018,-0.02337098,0.000074,0.02011032,-0.0562421,0.05542219,-0.03966066,-0.05034837,0.00265878,0.16876714,-0.01747699,-0.00957718,0.03607781,-0.03457591,0.05519032,-0.01482586,0.02643723,-0.02389111,-0.01334148,0.10325525,-0.02687407,0.02229503,0.07063684,0.00751179,0.01303734,0.00311521,-0.02296755,-0.01335008,-0.01075344,-0.03150456,0.03392278,0.07350949,-0.0443694,-0.02912825,-0.09288761,-0.02173612,0.05500451,-0.01860422,0.01263851,-0.02332316,0.06656358,-0.02260727,0.01084137,0.01516707,-0.02437714,0.00161652,0.00388008,-0.03568463,0.04467365,0.02245533,0.13097085,0.00705578],"last_embed":{"tokens":463,"hash":"1dhkjkh"}}},"last_read":{"hash":"1dhkjkh","at":1781675951909},"class_name":"SmartSource","last_import":{"mtime":1781284012000,"size":6461,"at":1781675837061,"hash":"1dhkjkh"},"blocks":{"#---frontmatter---":[1,35],"##Cosa è":[37,40],"##Cosa è#{1}":[39,40],"##Finalità":[41,44],"##Finalità#{1}":[43,44],"##Classificazione dei dispositivi medici":[45,48],"##Classificazione dei dispositivi medici#{1}":[47,48],"##Conformità e marcatura CE":[49,52],"##Conformità e marcatura CE#{1}":[51,52],"##EUDAMED e vigilanza":[53,56],"##EUDAMED e vigilanza#{1}":[55,56],"##Rilevanza per il laboratorio medico":[57,60],"##Rilevanza per il laboratorio medico#{1}":[59,60]},"outlinks":[{"title":"Regolamento UE 2017-746 (IVDR)","target":"Regolamento UE 2017-746 (IVDR)","line":29},{"title":"Unione Europea (Regolamenti Dispositivi Medici)","target":"Unione Europea (Regolamenti Dispositivi Medici)","line":30},{"title":"Dispositivi Medico-Diagnostici In Vitro (IVD)","target":"Dispositivi Medico-Diagnostici In Vitro (IVD)","line":31},{"title":"ISO 15189","target":"ISO 15189","line":32},{"title":".raw/unlocked_Regolamento UE 745_2017 - Regolamento relativo ai dispositivi medici.pdf","target":".raw/unlocked_Regolamento UE 745_2017 - Regolamento relativo ai dispositivi medici.pdf","line":34},{"title":"ISO 15189","target":"ISO 15189","line":59},{"title":"Regolamento UE 2017-746 (IVDR)","target":"Regolamento UE 2017-746 (IVDR)","line":59}],"metadata":{"type":"source","title":"Regolamento UE 2017/745 (MDR)","created":"2026-06-12","updated":"2026-06-12","tags":["#laboratorio-medico","#source","#normativa","#dispositivi-medici","#unione-europea"],"status":"developing","address":"c-000022","source_type":"regulation","author":"Parlamento Europeo e Consiglio dell'Unione Europea","date_published":"2017-05-05","url":"","confidence":"high","key_claims":["Il Regolamento (UE) 2017/745 (MDR) sostituisce le direttive 90/385/CEE (dispositivi medici impiantabili attivi) e 93/42/CEE (dispositivi medici) con un unico atto legislativo applicabile a tutti i dispositivi medici diversi dai dispositivi medico-diagnostici in vitro.","L'obiettivo del MDR è duplice e di pari rango: garantire il buon funzionamento del mercato interno UE per i dispositivi medici e fissare standard elevati di qualità e sicurezza a tutela di pazienti e utilizzatori.","I dispositivi medici sono classificati in quattro classi di rischio crescente - I, IIa, IIb, III - secondo le regole di classificazione dell'Allegato VIII, basate sulla destinazione d'uso, durata di contatto, invasività e parti del corpo coinvolte.","La marcatura CE attesta la conformità ai requisiti generali di sicurezza e prestazione (Allegato I) ed è condizione per l'immissione sul mercato e la libera circolazione nell'UE.","Per le classi di rischio superiori (IIa, IIb, III) la valutazione della conformità richiede il coinvolgimento di un organismo notificato, secondo le procedure degli Allegati IX-XI.","Il MDR istituisce EUDAMED, la banca dati europea dei dispositivi medici, per la tracciabilità di dispositivi, operatori economici, certificati, indagini cliniche, vigilanza e sorveglianza del mercato.","Il regolamento rafforza gli obblighi dei fabbricanti in materia di sistema di gestione della qualità, gestione del rischio, sorveglianza post-commercializzazione (PMS) e vigilanza (segnalazione di incidenti gravi e azioni correttive di sicurezza).","Per un laboratorio medico, il MDR è rilevante principalmente come quadro regolatorio dei dispositivi medici (non IVD) usati in ambito clinico/assistenziale - es. dispositivi di prelievo, strumentazione accessoria - mentre la regolamentazione specifica per reagenti, kit diagnostici e analizzatori di laboratorio è il Regolamento (UE) 2017/746 (IVDR)."],"related":["[[Regolamento UE 2017-746 (IVDR)]]","[[Unione Europea (Regolamenti Dispositivi Medici)]]","[[Dispositivi Medico-Diagnostici In Vitro (IVD)]]","[[ISO 15189]]"],"sources":["[[.raw/unlocked_Regolamento UE 745_2017 - Regolamento relativo ai dispositivi medici.pdf]]"]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"key":"Wiki/sources/Regolamento UE 2017-745 (MDR).md"},
