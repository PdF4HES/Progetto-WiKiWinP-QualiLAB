04607936,0.01290454,-0.07293913,0.07096199,-0.04360292,-0.07338133,-0.01337731,0.12859112,-0.02130233,-0.0321832,0.02934286,-0.04942264,0.0348831,0.03698027,0.06725609,-0.03705585,-0.03676523,0.17518063,0.04296247,0.02576834,0.03320013,-0.0481571,0.024812,-0.00197239,-0.06468026,-0.06922334,-0.00626694,-0.0346109,-0.01823609,0.05762214,-0.05560444,-0.02564863,-0.04741062,0.00122866,0.07377587,-0.02122907,-0.03104011,-0.06300126,0.03165217,-0.02693591,-0.03069214,0.03220657,0.0000443,-0.01091835,-0.02215885,-0.01515262,0.02392939,0.01248937,0.04678483,0.04577159],"last_embed":{"tokens":462,"hash":"1neg9uo"}}},"last_read":{"hash":"1neg9uo","at":1781675929845},"class_name":"SmartSource","last_import":{"mtime":1781282732000,"size":5204,"at":1781675837061,"hash":"1neg9uo"},"blocks":{"#---frontmatter---":[1,30],"##Sintesi":[32,35],"##Sintesi#{1}":[34,35],"##Logo, marchio istituzionale e marchio ad uso dei CAB":[36,39],"##Logo, marchio istituzionale e marchio ad uso dei CAB#{1}":[38,39],"##Uso sui rapporti di prova/referto dei laboratori medici":[40,43],"##Uso sui rapporti di prova/referto dei laboratori medici#{1}":[42,43],"##Sospensione, revoca e sanzioni":[44,47],"##Sospensione, revoca e sanzioni#{1}":[46,47],"##Collegamenti":[48,51],"##Collegamenti#{1}":[50,51]},"outlinks":[{"title":"ACCREDIA","target":"ACCREDIA","line":17},{"title":"ACCREDIA","target":"ACCREDIA","line":26},{"title":"ISO 15189","target":"ISO 15189","line":27},{"title":"Processo di Accreditamento","target":"Processo di Accreditamento","line":28},{"title":"Sistema di Gestione per la Qualità","target":"Sistema di Gestione per la Qualità","line":29},{"title":"RT-35","target":"ACCREDIA Prescrizioni Accreditamento ISO 15189","line":50},{"title":"Processo di Accreditamento","target":"Processo di Accreditamento","line":50},{"title":"Sistema di Gestione per la Qualità","target":"Sistema di Gestione per la Qualità","line":50}],"metadata":{"type":"source","title":"ACCREDIA Regolamento Logo e Marchio","created":"2026-06-12","updated":"2026-06-12","tags":["#laboratorio-medico","#source","#accreditamento","#marchio"],"status":"seed","address":"c-000009","source_type":"regulation","document_code":"RG-09","document_revision":"13","document_date":"2025-12-03","publisher":"[[ACCREDIA]]","key_claims":["Il marchio di accreditamento ad uso dei CAB è composto da due cerchi concentrici con pittogramma, denominazione ACCREDIA, sigla dello schema (es. MEDICAL EXAMINATIONS per ISO 15189) e numero di accreditamento a 5 cifre, sempre parte integrante del marchio.","Sui rapporti di prova/referto, il marchio ACCREDIA può comparire solo per esami effettivamente coperti dall'accreditamento; gli esami non accreditati vanno segnalati con il simbolo § (laboratori medici) e la dicitura 'attività non accreditata da ACCREDIA'.","È vietato l'uso del marchio su biglietti da visita, tesserini, firme email, documenti interni del SGQ (moduli, checklist, manuali, verbali) e su campioni/prodotti.","Per i laboratori medici è prevista una 'soluzione alternativa' (su richiesta scritta approvata da ACCREDIA): inserire nei referti la frase che rimanda all'elenco aggiornato degli esami accreditati pubblicato sul sito del laboratorio, in luogo del simbolo §.","La concessione d'uso del marchio decorre dalla delibera di accreditamento e accetta implicitamente il Regolamento; sospensione/revoca dell'accreditamento comporta sospensione o cessazione immediata e definitiva dell'uso del marchio per lo schema interessato.","Le violazioni sono sanzionate in ordine crescente: richiamo scritto con richiesta di azioni correttive, sospensione di tutti gli accreditamenti, revoca di tutti gli accreditamenti; l'uso doloso o fraudolento del marchio (protetto per legge) è perseguibile legalmente."],"related":["[[ACCREDIA]]","[[ISO 15189]]","[[Processo di Accreditamento]]","[[Sistema di Gestione per la Qualità]]"]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"key":"Wiki/sources/ACCREDIA Regolamento Logo e Marchio.md"},
