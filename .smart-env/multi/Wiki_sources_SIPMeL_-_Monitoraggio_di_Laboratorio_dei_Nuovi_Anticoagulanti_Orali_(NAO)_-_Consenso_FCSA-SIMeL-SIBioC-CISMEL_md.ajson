5,-0.30495545,0.00511869,-0.02775536,-0.11252402,0.02119816,-0.0281873,0.02144031,-0.0855417,-0.0605689,-0.03528391,-0.01497695,0.0372325,0.03765327,0.0290201,-0.00886711,-0.01120437,0.02951449,-0.01072315,0.02361349,-0.02459187,-0.01539186,-0.000257,0.13906358,-0.02462242,0.00548517,0.03224454,-0.04629645,-0.00552317,0.02506061,0.0352726,-0.04047068,-0.00296832,0.14844191,-0.01226542,0.01183641,0.07872387,-0.02582889,0.02388508,0.04728513,-0.02560302,-0.0647886,0.04134432,-0.03780146,0.02408237,0.03825121,-0.04539195,-0.06565406,-0.03977418,0.01762879,0.03387705,-0.02405175,-0.02810297,-0.00176789,0.02462205,0.01245704,-0.00324132,-0.01918167,0.00066296,-0.07423759,0.00737235,-0.02066574,0.00561506,-0.03613968,0.05630247,0.03185793],"last_embed":{"tokens":471,"hash":"1nv6lzf"}}},"last_read":{"hash":"1nv6lzf","at":1781675978713},"class_name":"SmartSource","last_import":{"mtime":1781340354000,"size":4940,"at":1781675837115,"hash":"1nv6lzf"},"blocks":{"#---frontmatter---":[1,28],"#":[30,32],"##Cosa è":[33,36],"##Cosa è#{1}":[35,36],"##Contenuti principali":[37,48],"##Contenuti principali#{1}":[39,48]},"outlinks":[{"title":"SIPMeL","target":"SIPMeL","line":24},{"title":"Gruppo di Studio Coagulazione SIPMeL","target":"Gruppo di Studio Coagulazione SIPMeL","line":25},{"title":"Monitoraggio di Laboratorio degli Anticoagulanti Orali Diretti (DOAC)","target":"Monitoraggio di Laboratorio degli Anticoagulanti Orali Diretti (DOAC)","line":26},{"title":"SIPMeL - Diagnostica di Laboratorio per Pazienti in Trattamento con DOAC (Consenso SISET-FCSA-SIBioC-SIPMeL)","target":"SIPMeL - Diagnostica di Laboratorio per Pazienti in Trattamento con DOAC (Consenso SISET-FCSA-SIBioC-SIPMeL)","line":27},{"title":"SIPMeL - Diagnostica di Laboratorio per Pazienti in Trattamento con DOAC (Consenso SISET-FCSA-SIBioC-SIPMeL)","target":"SIPMeL - Diagnostica di Laboratorio per Pazienti in Trattamento con DOAC (Consenso SISET-FCSA-SIBioC-SIPMeL)","line":31},{"title":"SIPMeL","target":"SIPMeL","line":35},{"title":"Monitoraggio di Laboratorio degli Anticoagulanti Orali Diretti (DOAC)","target":"Monitoraggio di Laboratorio degli Anticoagulanti Orali Diretti (DOAC)","line":47}],"metadata":{"type":"source","title":"SIPMeL - Monitoraggio di Laboratorio dei Nuovi Anticoagulanti Orali (NAO) - Consenso FCSA-SIMeL-SIBioC-CISMEL","created":"2026-06-13","updated":"2026-06-13","tags":["#laboratorio-medico","#source","#guideline","#coagulazione","#nao"],"status":"developing","address":"c-000120","source_type":"guideline","key_claims":["I NAO (nuovi anticoagulanti orali: dabigatran, rivaroxaban, apixaban) non richiedono monitoraggio di laboratorio stringente per evitare sovra o sotto-dosaggio, a differenza degli antagonisti della vitamina K (AVK).","Il monitoraggio è giustificato solo in condizioni particolari: emergenze emorragiche/trombotiche con terapia non nota, necessità di antagonizzazione rapida, interventi invasivi, insufficienza renale/epatica, interazioni farmacologiche, pesi corporei estremi.","Per dabigatran si raccomandano tempo di trombina diluito (dTT), tempo di ecarina (ECT) o tempo di trombina (TCT), espressi come rapporto paziente/normale o come concentrazione del farmaco tramite curve di calibrazione locali.","Per rivaroxaban si raccomandano l'attività anti-FXa (più sensibile a basse concentrazioni) o il PT (espresso come rapporto, non come INR).","Per apixaban non erano disponibili informazioni sufficienti per raccomandazioni definitive; si ritiene comunque applicabile per analogia quanto indicato per rivaroxaban.","I valori di picco si raggiungono circa 2 ore dopo l'assunzione, con successivo decadimento della concentrazione: la tempistica del prelievo rispetto alla dose è cruciale per l'interpretazione.","Antitrombina, fibrinogeno, resistenza alla proteina C attivata, proteina C, proteina S e Lupus Anticoagulant possono risultare alterati in modo eterogeneo dalla terapia con NAO."],"related":["[[SIPMeL]]","[[Gruppo di Studio Coagulazione SIPMeL]]","[[Monitoraggio di Laboratorio degli Anticoagulanti Orali Diretti (DOAC)]]","[[SIPMeL - Diagnostica di Laboratorio per Pazienti in Trattamento con DOAC (Consenso SISET-FCSA-SIBioC-SIPMeL)]]"]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"key":"Wiki/sources/SIPMeL - Monitoraggio di Laboratorio dei Nuovi Anticoagulanti Orali (NAO) - Consenso FCSA-SIMeL-SIBioC-CISMEL.md"},
