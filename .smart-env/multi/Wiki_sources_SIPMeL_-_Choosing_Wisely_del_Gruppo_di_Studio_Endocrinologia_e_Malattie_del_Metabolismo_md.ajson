0.00028404,-0.01282713,-0.00562515,-0.0296029,-0.0365089,-0.01020262,0.03804491,-0.01591405,0.05327896,0.06628207,-0.01766116,-0.0420801,0.04072034,-0.01895385,0.06469744,-0.03551026,-0.00918632,0.00952233,0.15853386,0.03986267,-0.01554506,0.05731933,-0.0025299,0.05394126,-0.00999976,0.04232396,-0.04159566,-0.01137524,0.09936845,-0.04954071,0.00667376,0.11191256,-0.03710152,0.00797666,0.00255165,-0.00588443,-0.02337305,0.00544224,-0.03122811,-0.0026156,0.10351423,-0.03820661,-0.0859764,0.01367426,0.0084039,0.01576757,-0.03261731,-0.02705094,-0.04326594,0.0267658,0.03917079,0.01313308,0.03220718,-0.02559109,-0.07342721,-0.00529635,-0.00672163,0.03449105,0.02458107,0.07633182,0.03463344],"last_embed":{"tokens":449,"hash":"1cgoav8"}}},"last_read":{"hash":"1cgoav8","at":1781675984152},"class_name":"SmartSource","last_import":{"mtime":1781353396000,"size":9078,"at":1781675837115,"hash":"1cgoav8"},"blocks":{"#---frontmatter---":[1,49],"##Cosa è":[51,57],"##Cosa è#{1}":[53,57],"##Il processo di selezione":[58,67],"##Il processo di selezione#{1}":[60,61],"##Il processo di selezione#{2}":[62,62],"##Il processo di selezione#{3}":[63,63],"##Il processo di selezione#{4}":[64,64],"##Il processo di selezione#{5}":[65,65],"##Il processo di selezione#{6}":[66,67],"##Le 5 raccomandazioni (con punteggio)":[68,78],"##Le 5 raccomandazioni (con punteggio)#{1}":[70,70],"##Le 5 raccomandazioni (con punteggio)#{2}":[71,71],"##Le 5 raccomandazioni (con punteggio)#{3}":[72,72],"##Le 5 raccomandazioni (con punteggio)#{4}":[73,73],"##Le 5 raccomandazioni (con punteggio)#{5}":[74,75],"##Le 5 raccomandazioni (con punteggio)#{6}":[76,78],"##Rilevanza per il quadro qualità/accreditamento":[79,82],"##Rilevanza per il quadro qualità/accreditamento#{1}":[81,82]},"outlinks":[{"title":"SIPMeL","target":"SIPMeL","line":33},{"title":"Gruppo di Studio Endocrinologia e Malattie del Metabolismo SIPMeL","target":"Gruppo di Studio Endocrinologia e Malattie del Metabolismo SIPMeL","line":34},{"title":"Appropriatezza Diagnostica e Choosing Wisely","target":"Appropriatezza Diagnostica e Choosing Wisely","line":35},{"title":"Diagnostica di Laboratorio della Sindrome di Cushing","target":"Diagnostica di Laboratorio della Sindrome di Cushing","line":36},{"title":"Diagnostica di Laboratorio del Feocromocitoma e Paraganglioma","target":"Diagnostica di Laboratorio del Feocromocitoma e Paraganglioma","line":37},{"title":"Intervalli di Riferimento e Limiti Decisionali","target":"Intervalli di Riferimento e Limiti Decisionali","line":38},{"title":"ISO 15189","target":"ISO 15189","line":39},{"title":"Gruppo di Studio Endocrinologia e Malattie del Metabolismo SIPMeL","target":"Gruppo di Studio Endocrinologia e Malattie del Metabolismo SIPMeL","line":53},{"title":"SIPMeL - Choosing Wisely del Gruppo di Studio Endocrinologia e Malattie del Metabolismo - Aggiornamento 2024","target":"SIPMeL - Choosing Wisely del Gruppo di Studio Endocrinologia e Malattie del Metabolismo - Aggiornamento 2024","line":56},{"title":"Appropriatezza Diagnostica e Choosing Wisely","target":"Appropriatezza Diagnostica e Choosing Wisely","line":81},{"title":"GdS-AI","target":"Gruppo di Studio in Autoimmunologia (GdS-AI) SIPMeL","line":81},{"title":"Intervalli di Riferimento e Limiti Decisionali","target":"Intervalli di Riferimento e Limiti Decisionali","line":81},{"title":"ISO 15189","target":"ISO 15189","line":81},{"title":"SIPMeL - Diagnostica di Laboratorio del Feocromocitoma e Paraganglioma","target":"SIPMeL - Diagnostica di Laboratorio del Feocromocitoma e Paraganglioma","line":81},{"title":"SIPMeL - Diagnostica di Laboratorio della Sindrome di Cushing","target":"SIPMeL - Diagnostica di Laboratorio della Sindrome di Cushing","line":81}],"metadata":{"type":"source","title":"SIPMeL - Choosing Wisely del Gruppo di Studio Endocrinologia e Malattie del Metabolismo","created":"2026-06-13","updated":"2026-06-13","tags":["#laboratorio-medico","#source","#guideline","#endocrinologia","#choosing-wisely","#sipmel"],"status":"developing","address":"c-000128","source_type":"guideline","year":2016,"authors":["Romolo M. Dorizzi","Anna Ferrari","Marina Vitillo","Beatrice Caruso","Claudio Cocco","Erennio Ciotoli","Federica D'Aurizio","Elisa Esposito","Germana Giannone","Giulio Ozzola","Ottavia Porzio","Emanuela Toffalori","Renato Tozzoli"],"publication":"Riv Ital Med Lab / RIME (manoscritto RIME-D-16-00005R1, presentato al 1° Congresso Nazionale SIPMeL, Roma, novembre 2015)","related":["[[SIPMeL]]","[[Gruppo di Studio Endocrinologia e Malattie del Metabolismo SIPMeL]]","[[Appropriatezza Diagnostica e Choosing Wisely]]","[[Diagnostica di Laboratorio della Sindrome di Cushing]]","[[Diagnostica di Laboratorio del Feocromocitoma e Paraganglioma]]","[[Intervalli di Riferimento e Limiti Decisionali]]","[[ISO 15189]]"],"key_claims":["Procedura 1 (punteggio 118, la più alta): nel sospetto di distiroidismo richiedere TSH o TSH Reflex, non un pannello tiroideo esteso; non eseguire screening in pazienti asintomatici; non richiedere fT3 per il monitoraggio della terapia con levotiroxina nell'ipotiroidismo (eccetto situazioni di asse ipofisi-tiroide non stabile: primi mesi di terapia, gravidanza, ipotiroidismo centrale, resistenza agli ormoni tiroidei, adenoma TSH-secernente, dove è appropriato TSH + fT4).","Procedura 2 (punteggio 100): per lo screening della sindrome di Cushing non richiedere cortisolo sierico e ACTH plasmatico random, 17-chetosteroidi urinari, test di tolleranza all'insulina, test alla loperamide, test al desametasone 8 mg; utilizzare invece uno tra: cortisolo libero urinario (almeno 2 raccolte 24h), cortisolo salivare notturno (2 campioni in giorni diversi, preferibile), o test di soppressione al desametasone overnight 1 mg o 2 mg/die x 48h.","Procedura 3 (punteggio 97): per la diagnosi di feocromocitoma non richiedere acido vanilmandelico urinario né catecolamine plasmatiche/urinarie (bassa sensibilità); richiedere invece metanefrine plasmatiche libere, o in alternativa metanefrine urinarie frazionate (alta sensibilità: un risultato negativo permette di escludere il feocromocitoma).","Procedura 4 (punteggio 93): nel sospetto di tireopatia autoimmune non richiedere insieme anti-TPO e anti-Tg, ma solo anti-TPO (circa il 5% delle tireopatie autoimmuni ha anti-TPO negativi e anti-Tg positivi); gli anti-TPO non vanno mai ripetuti in un paziente già risultato positivo; le variazioni anticorpali non guidano la terapia (che si basa sul TSH); gli anti-Tg vanno invece misurati insieme alla tireoglobulina nel follow-up del carcinoma differenziato della tiroide dopo tiroidectomia.","Procedura 5 (punteggio 90): la 25-OH vitamina D non deve essere usata come test di screening per l'ipovitaminosi nella popolazione generale, ma solo nei soggetti a rischio di deficienza (malassorbimento, immobilizzazione, scarsa esposizione solare, pelle scura a latitudini elevate, farmaci che causano deficit, IRC, obesità, granulomatosi croniche/linfomi, iperparatiroidismo primario) o nell'approfondimento di osteoporosi/miopatie prossimali; secondo Endocrine Society e USPSTF le prove a supporto dello screening generalizzato sono insufficienti e non vi è consenso sul cut-off di deficit.","Una sesta procedura (punteggio 60, non inclusa nella Top 5 finale) riguardava il testosterone libero: non richiedere la determinazione del testosterone libero con metodi immunometrici nel sospetto di iperandrogenismo e ipogonadismo.","La lista è stata costruita tramite un sondaggio 2015 tra i membri del GdS-EMM (fasi marzo-gennaio 2016): ciascun componente ha proposto fino a 5 procedure a rischio di inappropriatezza con punteggio 1-10, motivazione e bibliografia; il coordinatore (Anna Ferrari) ha aggregato i punteggi in una graduatoria, approvata dal gruppo e presentata al 1° Congresso Nazionale SIPMeL (Roma, novembre 2015) in una sessione congiunta SIPMeL-AME (Associazione Medici Endocrinologi).","Il documento richiama il confronto con la lista SIBioC (proposta a Slow Medicine) e con le liste Top 5 dell'American Society of Hematology (2015), evidenziando l'importanza di confrontare/integrare liste di Società diverse per rafforzarne l'autorevolezza e l'applicabilità."]},"task_lines":[],"tasks":{},"codeblock_ranges":[]},"smart_blocks:Wiki/sources/SIPMeL - Choosing Wisely del Gruppo di Studio Endocrinologia e Malattie del Metabolismo.md#---frontmatter---": {"path":null,"last_embed":{"hash":"1686e5p","at":1781675984718},"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.03341924,-0.01301075,0.01469736,0.04781869,0.01314781,-0.03227334,0.00334348,0.06292038,-0.01438719,-0.0230504,-0.02597816,-0.06344559,-0.0108733,0.08917186,0.03118587,-0.02555731,0.00471246,0.00493205,0.0154396,-0.02560654,0.10716277,-0.04147126,-0.02548823,-0.02655569,0.06987192,0.03922857,0.03793373,0.02339086,-0.06926353,-0.17875586,0.00466987,0.07295369,0.01344625,-0.06710528,-0.04178623,0.03759688,0.01651948,0.03876295,-0.01329463,0.05423197,0.0482547,0.04036726,0.00584789,-0.01346915,0.00087357,-0.01965776,-0.01135994,0.03728621,-0.02634997,0.00118404,-0.09027348,0.02739726,-0.0012448,0.07591008,-0.01411441,0.05598456,0.05154566,0.00746784,0.00303549,0.03018303,0.04602748,0.05381572,-0.2542538,0.02404722,0.01826842,0.01136693,-0.07426622,-0.00667195,-0.0217932,0.0058888,-0.00140283,-0.05763039,0.01366424,0.00338078,0.01261412,-0.00141725,0.02724472,-0.04563303,0.00282826,-0.03425913,-0.00632521,0.05293056,-0.01862452,0.01100274,-0.00391846,-0.01881426,0.00674862,0.00898612,0.00501574,-0.04171,-0.03247468,-0.04743235,0.02872759,0.05170545,0.02106125,0.01993646,-0.007905,0.01949962,-0.05906655,0.09799761,-0.01689429,-0.01261569,-0.02194695,-0.01334856,0.02221042,0.00376469,-0.02645417,-0.01308647,0.01688259,0.0391557,0.02150923,-0.02929553,0.07569891,-0.05537485,-0.05616028,0.05697836,0.04038341,-0.01962986,-0.01506921,0.05084658,0.02030147,-0.00954623,0.05539232,-0.02225897,0.01475545,-0.01303877,-0.0127272,0.05359173,0.06492201,0.05389469,0.08902016,0.0514316,-0.04772526,0.030381