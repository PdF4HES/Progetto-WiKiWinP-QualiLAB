1,-0.00596344,0.06053386,0.06175905,-0.0125429,0.00374533,0.00475983,0.01118371,0.01616998,-0.02294405,-0.04651318,0.03248039,0.12437718,0.01330704,-0.00826615,0.0384594,-0.01406934,0.0692435,-0.00603143,0.03596316,-0.04464617,-0.00506281,0.11253918,0.02911747,-0.00178557,0.11495005,-0.0150384,0.02250751,0.02428769,0.00244222,-0.02378791,-0.04238879,-0.03784505,0.0395784,0.07759277,-0.05383532,-0.10692222,-0.0264686,-0.01839002,0.01604524,-0.02045921,-0.01991946,-0.0339855,0.04857065,0.00602712,0.00517093,0.02339205,-0.01567717,-0.0811269,-0.00363601,-0.00802367,-0.00118886,-0.01290001,0.07439507,0.04236677],"last_embed":{"tokens":441,"hash":"jrgnax"}}},"last_read":{"hash":"jrgnax","at":1781675973730},"class_name":"SmartSource","last_import":{"mtime":1781329310000,"size":6649,"at":1781675837115,"hash":"jrgnax"},"blocks":{"#---frontmatter---":[1,39],"##Sintesi":[41,44],"##Sintesi#{1}":[43,44],"##Contenuti principali":[45,50],"##Contenuti principali#{1}":[47,50],"##Rilevanza per la wiki":[51,54],"##Rilevanza per la wiki#{1}":[53,54]},"outlinks":[{"title":"SIPMeL","target":"SIPMeL","line":23},{"title":"Gruppo di Studio Endocrinologia e Malattie del Metabolismo SIPMeL","target":"Gruppo di Studio Endocrinologia e Malattie del Metabolismo SIPMeL","line":24},{"title":"Diagnostica di Laboratorio delle Malattie del Surrene","target":"Diagnostica di Laboratorio delle Malattie del Surrene","line":25},{"title":"Steroidi Surrenalici e Iperplasia Adrenocorticale Congenita (CAH)","target":"Steroidi Surrenalici e Iperplasia Adrenocorticale Congenita (CAH)","line":26},{"title":"Intervalli di Riferimento e Limiti Decisionali","target":"Intervalli di Riferimento e Limiti Decisionali","line":27},{"title":"Validazione e Verifica dei Metodi Analitici","target":"Validazione e Verifica dei Metodi Analitici","line":28},{"title":"ISO 15189","target":"ISO 15189","line":29},{"title":"Gruppo di Studio Endocrinologia e Malattie del Metabolismo SIPMeL","target":"Gruppo di Studio Endocrinologia e Malattie del Metabolismo SIPMeL","line":43},{"title":"Diagnostica di Laboratorio delle Malattie del Surrene","target":"Diagnostica di Laboratorio delle Malattie del Surrene","line":53},{"title":"Intervalli di Riferimento e Limiti Decisionali","target":"Intervalli di Riferimento e Limiti Decisionali","line":53},{"title":"Steroidi Surrenalici e Iperplasia Adrenocorticale Congenita (CAH)","target":"Steroidi Surrenalici e Iperplasia Adrenocorticale Congenita (CAH)","line":53},{"title":"Validazione e Verifica dei Metodi Analitici","target":"Validazione e Verifica dei Metodi Analitici","line":53}],"metadata":{"type":"source","title":"SIPMeL - 17-Idrossiprogesterone (17-OHP)","created":"2026-06-13","updated":"2026-06-13","tags":["#laboratorio-medico","#source","#sipmel","#endocrinologia","#surrene","#steroidi"],"status":"developing","address":"c-000101","source_type":"guideline","authors":["Annamaria D'Alessandro","Ottavia Porzio","Gruppo di Studio Endocrinologia e Malattie del Metabolismo (GdS-EMM) - SIPMeL"],"publication":"La Rivista Italiana della Medicina di Laboratorio / Italian Journal of Laboratory Medicine, 2024","file":".raw/unlocked_SIPMEL - Ormoni steroidei surrenalici. 17-idrossiprogesterone.pdf","related":["[[SIPMeL]]","[[Gruppo di Studio Endocrinologia e Malattie del Metabolismo SIPMeL]]","[[Diagnostica di Laboratorio delle Malattie del Surrene]]","[[Steroidi Surrenalici e Iperplasia Adrenocorticale Congenita (CAH)]]","[[Intervalli di Riferimento e Limiti Decisionali]]","[[Validazione e Verifica dei Metodi Analitici]]","[[ISO 15189]]"],"key_claims":["Il 17-idrossiprogesterone (17-OHP) è uno steroide intermedio della steroidogenesi surrenalica, prodotto nella zona fascicolata dalla conversione di progesterone e 17-idrossipregnenolone, e convertito in 11-deossicortisolo dall'enzima 21-idrossilasi (CYP21A2).","Concentrazioni di 17-OHP >240 nmol/L (>80 ng/mL) in un campione prelevato in qualsiasi momento della giornata sono diagnostiche per deficit di 21-idrossilasi (iperplasia surrenalica congenita, CAH/SAG); circa il 90% dei casi di CAH è dovuto a mutazioni del gene CYP21A2.","In presenza di concentrazioni basali di 17-OHP >2,0 ng/mL (>6 nmol/L) ma <33 ng/mL (<100 nmol/L), suggestive della forma Non Classica, è indicata la determinazione del 17-OHP dopo test da stimolo con ACTH sintetico (250 microg e.v. o i.m., prelievo basale e a 60 minuti): concentrazioni post-stimolo >10 ng/mL (>30 nmol/L) confermano il deficit di 21-idrossilasi (Endocrine Society).","I valori basali normali sono generalmente <1,0 ng/mL nel bambino; nella forma Classica i livelli basali sono spesso >100 ng/mL, senza necessità di test da stimolo.","Il 17-OHP dovrebbe essere misurato in tutte le condizioni cliniche di iperandrogenismo (pubarca precoce, irsutismo, acne, irregolarità mestruali, infertilità) per la diagnosi differenziale con la CAH.","Lo screening neonatale del deficit di 21-idrossilasi tramite 17-OHP su DBS (dried blood spot) è obbligatorio in tutti gli USA e in oltre 40 paesi; in Italia è attivo solo in alcune Regioni (Abruzzo, Emilia Romagna, Lombardia) in assenza di un decreto nazionale; i neonati pretermine o con stress perinatale possono mostrare falsi positivi per livelli fisiologicamente più elevati di 17-OHP.","La LC-MS/MS rappresenta il gold standard per la determinazione del 17-OHP: maggiore specificità, assenza di interferenze farmacologiche (a differenza dei metodi immunometrici/ELISA/RIA, gravati da cross-reattività con steroidi chimicamente affini come androstenedione, cortisolo, 11-deossicortisolo, progesterone, DEA) e possibilità di misura simultanea di un intero pannello steroideo.","I valori di riferimento del 17-OHP devono essere differenziati per sesso, età (con particolare attenzione al periodo neonatale, quando i livelli sono fisiologicamente elevati e calano rapidamente) e tecnologia di analisi utilizzata; il referto deve specificare metodo e/o analizzatore impiegato."]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"key":"Wiki/sources/SIPMeL - 17-Idrossiprogesterone (17-OHP).md"},
