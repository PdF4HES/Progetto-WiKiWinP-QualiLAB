1,0.04554441,0.01487635,0.02540227,-0.04280068,-0.02687447,0.0331528,0.17281069,-0.01213653,-0.02610137,0.01207857,-0.05126454,0.03676731,0.02031647,0.05281429,-0.03507365,-0.03736552,0.12409161,-0.02287054,-0.01965934,0.04029286,-0.0096513,0.02188918,0.00158046,-0.0422267,-0.13608198,-0.02468524,-0.03050832,0.02756049,0.09285416,0.01068189,-0.06539536,-0.0614852,0.00736115,0.04541817,-0.02695824,0.00590478,-0.02053791,0.0314939,-0.03160125,0.01514966,0.01175135,-0.00277775,-0.02126835,-0.03410451,-0.00162427,0.04751369,-0.01132451,0.06490361,0.00632207],"last_embed":{"tokens":459,"hash":"1s7x440"}}},"last_read":{"hash":"1s7x440","at":1781675929305},"class_name":"SmartSource","last_import":{"mtime":1781282226000,"size":5534,"at":1781675837061,"hash":"1s7x440"},"blocks":{"#---frontmatter---":[1,34],"##Sintesi":[36,59],"##Sintesi#{1}":[38,42],"##Sintesi#{2}":[43,43],"##Sintesi#{3}":[44,44],"##Sintesi#{4}":[45,45],"##Sintesi#{5}":[46,46],"##Sintesi#{6}":[47,47],"##Sintesi#{7}":[48,48],"##Sintesi#{8}":[49,49],"##Sintesi#{9}":[50,50],"##Sintesi#{10}":[51,51],"##Sintesi#{11}":[52,52],"##Sintesi#{12}":[53,53],"##Sintesi#{13}":[54,55],"##Sintesi#{14}":[56,59]},"outlinks":[{"title":"ISO 15189","target":"ISO 15189","line":14},{"title":"Sistema di Gestione per la Qualità","target":"Sistema di Gestione per la Qualità","line":15},{"title":"ACCREDIA","target":"ACCREDIA","line":16},{"title":"SIPMeL","target":"SIPMeL","line":17},{"title":".raw/unlocked_UNI EN ISO 15189_2024 - Laboratori Medici - Requisiti Riguardanti la Qualità e la Competenza.pdf","target":".raw/unlocked_UNI EN ISO 15189_2024 - Laboratori Medici - Requisiti Riguardanti la Qualità e la Competenza.pdf","line":19},{"title":"ACCREDIA","target":"ACCREDIA","line":40},{"title":"ACCREDIA","target":"ACCREDIA","line":58},{"title":"SIPMeL","target":"SIPMeL","line":58}],"metadata":{"type":"source","title":"UNI EN ISO 15189:2024 - Laboratori Medici, Requisiti riguardanti la Qualità e la Competenza","created":"2026-06-12","updated":"2026-06-12","tags":["#laboratorio-medico","#source","#normativa","#accreditamento"],"status":"developing","address":"c-000001","related":["[[ISO 15189]]","[[Sistema di Gestione per la Qualità]]","[[ACCREDIA]]","[[SIPMeL]]"],"sources":["[[.raw/unlocked_UNI EN ISO 15189_2024 - Laboratori Medici - Requisiti Riguardanti la Qualità e la Competenza.pdf]]"],"source_type":"regulation/standard","author":"ISO/TC 212 - CEN/TC 140 - UNI","date_published":"2024-06-01","url":"","confidence":"high","key_claims":["La norma specifica i requisiti riguardanti la qualità e la competenza dei laboratori medici, applicabile anche agli esami al punto di cura (POCT).","È la versione italiana ufficiale della EN ISO 15189:2022 con l'aggiornamento A11:2023, e sostituisce sia la ISO 15189:2012 sia la ISO 22870:2016 (POCT).","La struttura della norma è allineata alla ISO/IEC 17025:2017, con i requisiti del sistema di gestione collocati al punto 8, in coda al documento.","I requisiti coprono: requisiti generali (imparzialità, riservatezza, requisiti relativi ai pazienti), requisiti strutturali e di governance, requisiti relativi alle risorse, requisiti di processo (pre-esame, esame, post-esame, gestione dati) e requisiti del sistema di gestione.","L'Appendice A normativa definisce requisiti aggiuntivi specifici per il POCT (point-of-care testing).","Le Appendici B e C (informative) forniscono tabelle di corrispondenza con ISO 9001:2015, ISO/IEC 17025:2017 e con l'edizione precedente ISO 15189:2012.","I requisiti per la gestione del rischio sono allineati alla ISO 22367; quelli per la sicurezza di laboratorio alla ISO 15190; quelli per raccolta e trasporto campioni alla ISO 20658.","Un laboratorio che richiede l'accreditamento dovrebbe scegliere un organismo di accreditamento conforme alla ISO/IEC 17011 (in Italia, ACCREDIA)."]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"key":"Wiki/sources/ISO 15189-2024.md"},
