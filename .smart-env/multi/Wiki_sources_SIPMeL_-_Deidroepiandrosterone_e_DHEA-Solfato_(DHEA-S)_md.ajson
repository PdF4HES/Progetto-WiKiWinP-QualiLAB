-0.02557843,0.03551156,-0.00320529,0.01353255,0.06400602,-0.03116198,0.00289228,-0.01828875,0.0360982,0.00754312,-0.05513733,-0.01942325,-0.01335776,0.13944525,-0.01434859,0.00165072,0.04144381,-0.02328698,0.07012591,-0.04196825,0.0534471,-0.03405672,0.01178536,0.07677913,0.07954948,-0.01527712,0.136222,-0.02270259,0.03271523,0.01234606,-0.03757961,-0.01910833,-0.01685096,-0.03065421,0.0750869,0.0733394,-0.05136183,-0.0996841,-0.02413396,0.04998108,0.0164758,-0.00890017,-0.03041363,-0.01604578,0.07881541,-0.01334585,0.00172266,0.05510167,-0.04505644,-0.09935773,-0.03560635,-0.02149873,0.07286596,-0.01741678,0.08944914,0.05263923],"last_embed":{"tokens":469,"hash":"201fzi"}}},"last_read":{"hash":"201fzi","at":1781675974343},"class_name":"SmartSource","last_import":{"mtime":1781329630000,"size":7947,"at":1781675837115,"hash":"201fzi"},"blocks":{"#---frontmatter---":[1,41],"##Sintesi":[43,46],"##Sintesi#{1}":[45,46],"##Contenuti principali":[47,54],"##Contenuti principali#{1}":[49,54],"##Raccomandazioni del GdS-EMM":[55,63],"##Raccomandazioni del GdS-EMM#{1}":[57,57],"##Raccomandazioni del GdS-EMM#{2}":[58,58],"##Raccomandazioni del GdS-EMM#{3}":[59,59],"##Raccomandazioni del GdS-EMM#{4}":[60,60],"##Raccomandazioni del GdS-EMM#{5}":[61,61],"##Raccomandazioni del GdS-EMM#{6}":[62,63],"##Rilevanza per la wiki":[64,67],"##Rilevanza per la wiki#{1}":[66,67]},"outlinks":[{"title":"SIPMeL","target":"SIPMeL","line":23},{"title":"Gruppo di Studio Endocrinologia e Malattie del Metabolismo SIPMeL","target":"Gruppo di Studio Endocrinologia e Malattie del Metabolismo SIPMeL","line":24},{"title":"Diagnostica di Laboratorio delle Malattie del Surrene","target":"Diagnostica di Laboratorio delle Malattie del Surrene","line":25},{"title":"Steroidi Surrenalici e Iperplasia Adrenocorticale Congenita (CAH)","target":"Steroidi Surrenalici e Iperplasia Adrenocorticale Congenita (CAH)","line":26},{"title":"SIPMeL - 17-Idrossiprogesterone (17-OHP)","target":"SIPMeL - 17-Idrossiprogesterone (17-OHP)","line":27},{"title":"SIPMeL - Androstenedione","target":"SIPMeL - Androstenedione","line":28},{"title":"Intervalli di Riferimento e Limiti Decisionali","target":"Intervalli di Riferimento e Limiti Decisionali","line":29},{"title":"Validazione e Verifica dei Metodi Analitici","target":"Validazione e Verifica dei Metodi Analitici","line":30},{"title":"ISO 15189","target":"ISO 15189","line":31},{"title":"Gruppo di Studio Endocrinologia e Malattie del Metabolismo SIPMeL","target":"Gruppo di Studio Endocrinologia e Malattie del Metabolismo SIPMeL","line":45},{"title":"Intervalli di Riferimento e Limiti Decisionali","target":"Intervalli di Riferimento e Limiti Decisionali","line":66},{"title":"ISO 15189","target":"ISO 15189","line":66},{"title":"SIPMeL - 17-Idrossiprogesterone (17-OHP)","target":"SIPMeL - 17-Idrossiprogesterone (17-OHP)","line":66},{"title":"SIPMeL - Androstenedione","target":"SIPMeL - Androstenedione","line":66},{"title":"Steroidi Surrenalici e Iperplasia Adrenocorticale Congenita (CAH)","target":"Steroidi Surrenalici e Iperplasia Adrenocorticale Congenita (CAH)","line":66},{"title":"Validazione e Verifica dei Metodi Analitici","target":"Validazione e Verifica dei Metodi Analitici","line":66}],"metadata":{"type":"source","title":"SIPMeL - Deidroepiandrosterone e DHEA-Solfato (DHEA-S)","created":"2026-06-13","updated":"2026-06-13","tags":["#laboratorio-medico","#source","#sipmel","#endocrinologia","#surrene","#steroidi"],"status":"developing","address":"c-000104","source_type":"guideline","authors":["Romolo M. Dorizzi","Vincenzo Brescia","Gruppo di Studio Endocrinologia e Malattie del Metabolismo (GdS-EMM) - SIPMeL"],"publication":"La Rivista Italiana della Medicina di Laboratorio / Italian Journal of Laboratory Medicine, 2024 Oct 14","file":".raw/unlocked_SIPMEL - Ormoni steroidei surrenalici. Deidroepiandrosterone e deidroepiandrosterone-solfato.pdf","related":["[[SIPMeL]]","[[Gruppo di Studio Endocrinologia e Malattie del Metabolismo SIPMeL]]","[[Diagnostica di Laboratorio delle Malattie del Surrene]]","[[Steroidi Surrenalici e Iperplasia Adrenocorticale Congenita (CAH)]]","[[SIPMeL - 17-Idrossiprogesterone (17-OHP)]]","[[SIPMeL - Androstenedione]]","[[Intervalli di Riferimento e Limiti Decisionali]]","[[Validazione e Verifica dei Metodi Analitici]]","[[ISO 15189]]"],"key_claims":["DHEA (deidroepiandrosterone) e DHEA-S (DHEA-solfato) sono pro-ormoni che non attivano direttamente il recettore degli androgeni ma possono essere convertiti in androgeni attivi (testosterone, DHT) nei tessuti periferici; il DHEA è convertito in DHEA-S dalla sulfotransferasi SULT2A1.","Il DHEA-S si lega fortemente all'albumina e raggiunge concentrazioni circolanti oltre 100 volte superiori a quelle del DHEA; ha un'emivita prolungata (10-16 ore) con livelli stabili durante il giorno, a differenza del DHEA (emivita 25 minuti, ritmo circadiano ACTH-dipendente), il che lo rende il marcatore preferito nella pratica clinica per la sua maggiore stabilità.","Le principali indicazioni cliniche alla misurazione di DHEA/DHEA-S sono: diagnosi differenziale dell'iperandrogenismo (in combinazione con altri steroidi sessuali), supporto alla diagnosi di iperplasia surrenalica congenita (CAH, ruolo secondario rispetto a cortisolo/cortisone, 17-OHP e androstenedione) e diagnosi differenziale dell'adrenarca prematuro, dove il DHEA-S è più diagnostico di testosterone e androstenedione.","Concentrazioni di DHEA/DHEA-S superiori a 5 volte il limite superiore di riferimento sono suggestive di tumori surrenalici (in particolare carcinomi secernenti androgeni, fino al 90% dei casi); nella CAH da deficit di 3β-idrossisteroide deidrogenasi, DHEA/DHEA-S sono elevati 5-10 volte il limite superiore già in epoca infantile.","Le linee guida Endocrine Society 2018 sulla PCOS indicano che il DHEA-S può essere misurato (qualità dell'evidenza molto bassa, scarsa specificità e calo età-dipendente) quando testosterone totale e libero non sono elevati, e raccomandano l'uso di metodi LC-MS/MS validati per testosterone totale e DHEA-S piuttosto che immunometrici.","Il DHEA-S è molto elevato nel cordone ombelicale, cala dell'80% nelle prime settimane di vita, rimane basso fino all'adrenarca, risale a valori paragonabili a quelli neonatali intorno alla terza decade, poi declina del 2-3%/anno fino all'\"adrenopausa\" (circa 20% del picco nell'8a-9a decade), processo indipendente dalla menopausa.","Confronti tra metodi immunometrici e LC-MS/MS mostrano forte disomogeneità: in uno studio olandese su 75 volontari, alcuni analizzatori (Abbott Architect, Siemens Advia Centaur, Roche Modular) sovrastimavano il DHEA-S del 14-28% rispetto all'ID-LC-MS/MS, mentre il consorzio Harmoster (2015) ha rilevato una variabilità analitica del 22% per il DHEA tra sette metodi pubblicati.","Non esistono prove cliniche solide a supporto della supplementazione di DHEA per disturbi legati all'invecchiamento (forza muscolare, mortalità cardiovascolare, tono dell'umore, declino cognitivo): revisioni sistematiche, incluse Cochrane, non ne supportano l'uso, e l'American Cancer Society raccomanda cautela nei tumori hormone-responsive."]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"key":"Wiki/sources/SIPMeL - Deidroepiandrosterone e DHEA-Solfato (DHEA-S).md"},
