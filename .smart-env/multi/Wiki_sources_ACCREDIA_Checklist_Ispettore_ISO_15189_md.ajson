01845023,-0.03667784,-0.02294272,0.03742043,0.05056291,-0.02142536,0.04726792,-0.0315357,-0.02083247,-0.01650595,0.19016266,-0.01400366,-0.02506028,0.05356003,-0.06286242,0.05262249,0.03386647,0.03936869,-0.03391201,-0.05016815,0.15607555,-0.00844223,-0.0231638,0.05306143,-0.00134954,0.0472394,0.03347214,-0.05362954,-0.10689636,-0.03288162,-0.06575599,0.00870275,0.06063584,-0.03779874,-0.09889115,-0.04888564,-0.00205386,0.06557661,-0.0495686,-0.02594218,-0.03655377,0.03656766,-0.021723,0.01490805,-0.01204591,-0.01169296,-0.01262631,-0.01687939,0.00074026,-0.01730798,0.00797332,0.03445925,0.02660899],"last_embed":{"tokens":467,"hash":"3mzio5"}}},"last_read":{"hash":"3mzio5","at":1781675950726},"class_name":"SmartSource","last_import":{"mtime":1781283282000,"size":6158,"at":1781675837061,"hash":"3mzio5"},"blocks":{"#---frontmatter---":[1,34],"##Cosa è":[36,39],"##Cosa è#{1}":[38,39],"##Struttura e flusso della visita":[40,43],"##Struttura e flusso della visita#{1}":[42,43],"##Aree di verifica per clausola":[44,47],"##Aree di verifica per clausola#{1}":[46,47],"##Rilevanza":[48,51],"##Rilevanza#{1}":[50,51]},"outlinks":[{"title":"Processo di Accreditamento","target":"Processo di Accreditamento","line":28},{"title":"ISO 15189","target":"ISO 15189","line":29},{"title":"Audit Interno e Visita Ispettiva","target":"Audit Interno e Visita Ispettiva","line":30},{"title":"ACCREDIA","target":"ACCREDIA","line":31},{"title":".raw/ACCREDIA - Checklist Ispettore di Sistema ISO 15189 (Accredia).docx","target":".raw/ACCREDIA - Checklist Ispettore di Sistema ISO 15189 (Accredia).docx","line":33},{"title":"ISO 15189","target":"ISO 15189","line":38},{"title":"visita ispettiva","target":"Processo di Accreditamento","line":38},{"title":"audit interni","target":"Audit Interno e Visita Ispettiva","line":46},{"title":"ACCREDIA Prescrizioni Accreditamento ISO 15189","target":"ACCREDIA Prescrizioni Accreditamento ISO 15189","line":50},{"title":"Processo di Accreditamento","target":"Processo di Accreditamento","line":50}],"metadata":{"type":"source","title":"ACCREDIA Checklist Ispettore ISO 15189","created":"2026-06-12","updated":"2026-06-12","tags":["#laboratorio-medico","#source","#checklist","#accredia","#accreditamento"],"status":"developing","address":"c-000013","source_type":"checklist","document_code":"Checklist Ispettore di Sistema ISO 15189 (ACCREDIA)","document_date":"2024/2025 (rev. corrente, basata su UNI EN ISO 15189:2024 e RG-02, RT-35, RG-09, RT-26, RT-39)","publisher":"ACCREDIA - Dipartimento Laboratori di Prova","key_claims":["La checklist è lo strumento operativo con cui l'ispettore di sistema ACCREDIA conduce la visita ispettiva (visita di valutazione): non è un documento prescrittivo ma una guida, da integrare con ulteriori punti di verifica e con il supporto dell'ispettore tecnico per i requisiti tecnici specifici.","È strutturata per ricalcare l'indice di UNI EN ISO 15189:2024: §4 Requisiti generali (Imparzialità, Riservatezza, Requisiti relativi ai pazienti), §5 Requisiti strutturali e di governance, §6 Requisiti relativi alle risorse, §7 Requisiti di processo, §8 Requisiti del sistema di gestione - più sezioni dedicate a POCT (in carattere azzurro nel documento originale, ai sensi dell'Allegato A di RT-35).","Include sezioni amministrative per la conduzione della visita: §1 Informazioni generali (sedi, team, rappresentante Direzione ACCREDIA, osservatori), §2 Piano delle verifiche (calendario per clausola e funzioni da intervistare), §3 Verifiche preliminari (campo di accreditamento flessibile RT-26, sospensioni pregresse, reclami).","Definisce il rito della visita: riunione interna del team preliminare all'apertura, riunione iniziale con il laboratorio (presentazione team, finalità, piano, sicurezza/DPI), conduzione delle verifiche, riunione interna preliminare alla chiusura, riunione finale (notifica rilievi tramite applicativo 3A, riserve del laboratorio).","Il §5 (Requisiti strutturali e di governance) verifica identità giuridica, nomina e responsabilità del Direttore del Laboratorio, coerenza tra campo di accreditamento e Manuale Qualità/Self Assessment, organigramma, politica e obiettivi per la qualità, gestione dei rischi e opportunità (collegamento a §8.5).","Il §8 (Requisiti del sistema di gestione) copre in dettaglio: 8.2 documentazione, 8.3 controllo documenti (incl. obbligo di applicare documenti esterni aggiornati entro 3 mesi dall'emissione), 8.4 controllo delle registrazioni (tracciabilità delle modifiche, tempi di conservazione coerenti con RT-35), 8.5 rischi e opportunità, 8.6 miglioramento (feedback da pazienti/utenti/personale), 8.7 non conformità e azioni correttive, 8.8 valutazioni (indicatori di qualità, audit interni programmati per rischio), 8.9 riesame di Direzione (input/output dettagliati).","I rilievi (non conformità) emersi durante la visita sono classificati e registrati nell'applicativo ACCREDIA '3A', con riferimento alla procedura PG-09-DL per formulazione e registrazione; eventuali riserve del Laboratorio vanno caricate sul 3A entro termini prestabiliti.","La checklist può essere usata dai laboratori come strumento di autovalutazione, ma ACCREDIA ne sconsiglia esplicitamente l'uso come traccia per gli audit interni del laboratorio."],"related":["[[Processo di Accreditamento]]","[[ISO 15189]]","[[Audit Interno e Visita Ispettiva]]","[[ACCREDIA]]"],"sources":["[[.raw/ACCREDIA - Checklist Ispettore di Sistema ISO 15189 (Accredia).docx]]"]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"key":"Wiki/sources/ACCREDIA Checklist Ispettore ISO 15189.md"},
