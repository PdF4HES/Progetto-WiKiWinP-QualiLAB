441,0.00846022,-0.01865552,-0.01393005,-0.04158313,-0.01872005,-0.01073968,-0.0479309,0.04522845,0.0414812,0.02008379,-0.0003176,-0.01326242,-0.02884991,-0.01219683,-0.01684248,-0.00982767,-0.02457448,0.07464767,0.19109897,0.00334463,-0.00171439,0.03730553,-0.03495523,0.03042213,-0.07611121,0.06840693,-0.05018903,-0.0303432,0.08596318,0.03247928,0.00476517,0.0372735,-0.00548599,0.07666513,-0.0307778,0.01440895,-0.08205556,0.00502857,-0.04480492,0.00708329,0.05658615,-0.00977319,-0.07062864,-0.01853167,0.0018735,0.06579878,-0.04013243,-0.02690503,-0.00667526,0.00193906,0.00880813,-0.02153684,-0.00446582,0.00993912,-0.03266063,-0.02094059,-0.03134768,-0.00449867,-0.03042626,0.071391,0.03109878],"last_embed":{"tokens":456,"hash":"1ut3k5p"}}},"last_read":{"hash":"1ut3k5p","at":1781675959918},"class_name":"SmartSource","last_import":{"mtime":1781297160000,"size":5782,"at":1781675837115,"hash":"1ut3k5p"},"blocks":{"#---frontmatter---":[1,32],"##Cosa è":[34,37],"##Cosa è#{1}":[36,37],"##Razionale e metodo":[38,41],"##Razionale e metodo#{1}":[40,41],"##Risultati principali":[42,45],"##Risultati principali#{1}":[44,45],"##Implicazioni":[46,49],"##Implicazioni#{1}":[48,49]},"outlinks":[{"title":"SIPMeL","target":"SIPMeL","line":23},{"title":"Gruppo di Studio sui Marcatori Miocardici (GdS MM) SIPMeL","target":"Gruppo di Studio sui Marcatori Miocardici (GdS MM) SIPMeL","line":24},{"title":"SIPMeL - Falsi Positivi e Falsi Negativi di Troponina - Parte I (Revisione Letteratura)","target":"SIPMeL - Falsi Positivi e Falsi Negativi di Troponina - Parte I (Revisione Letteratura)","line":25},{"title":"SIPMeL - Falsi Positivi e Falsi Negativi di Troponina - Parte II (Indagine GdS MM)","target":"SIPMeL - Falsi Positivi e Falsi Negativi di Troponina - Parte II (Indagine GdS MM)","line":26},{"title":"SIPMeL - Falsi Positivi e Falsi Negativi di Troponina - Parte IV (Raccomandazioni GdS MM)","target":"SIPMeL - Falsi Positivi e Falsi Negativi di Troponina - Parte IV (Raccomandazioni GdS MM)","line":27},{"title":"Troponina Cardiaca ad Alta Sensibilità (hs-cTn)","target":"Troponina Cardiaca ad Alta Sensibilità (hs-cTn)","line":28},{"title":"Falsi Positivi e Falsi Negativi in Diagnostica di Laboratorio","target":"Falsi Positivi e Falsi Negativi in Diagnostica di Laboratorio","line":29},{"title":"Validazione e Verifica dei Metodi Analitici","target":"Validazione e Verifica dei Metodi Analitici","line":30},{"title":"ISO 15189","target":"ISO 15189","line":31},{"title":"Gruppo di Studio sui Marcatori Miocardici (GdS MM) SIPMeL","target":"Gruppo di Studio sui Marcatori Miocardici (GdS MM) SIPMeL","line":36},{"title":"Parte I","target":"SIPMeL - Falsi Positivi e Falsi Negativi di Troponina - Parte I (Revisione Letteratura)","line":36},{"title":"Parte II","target":"SIPMeL - Falsi Positivi e Falsi Negativi di Troponina - Parte II (Indagine GdS MM)","line":36},{"title":"Parte IV","target":"SIPMeL - Falsi Positivi e Falsi Negativi di Troponina - Parte IV (Raccomandazioni GdS MM)","line":48}],"metadata":{"type":"source","title":"SIPMeL - Falsi Positivi e Falsi Negativi di Troponina - Parte III (Ruolo Industria)","created":"2026-06-12","updated":"2026-06-12","tags":["#laboratorio-medico","#source","#troponina","#sipmel"],"status":"developing","address":"c-000056","source_type":"guideline/review","key_claims":["Il GdS MM ha esaminato i foglietti illustrativi (data sheet/IFU) dei metodi hs-cTn disponibili sul mercato italiano (Abbott, Beckman, bioMérieux, Mitsubishi/PATHFAST, Roche, Siemens, Tosoh) confrontandone le informazioni sulle interferenze con lo schema del position paper GdS MM sui FP/FN di cTn.","Di cinque produttori con dati comparabili, tutti (5/5) indicano i limiti di interferenza per emolisi, lipemia e bilirubina, le caratteristiche della matrice/provetta, la stabilità a diverse temperature e la possibile interferenza da fattore reumatoide.","Quattro su cinque segnalano i livelli interferenti di biotina, i possibili problemi da fibrina e la possibilità di interferenza da anticorpi eterofili/HAMA; tre su cinque avvertono della possibile presenza di anticorpi contro i reagenti del metodo.","Solo uno su cinque segnala l'interferenza da iperfosfatasemia alcalina e da autoanticorpi anti-cTn, e indica quali provette sono validate; nessun produttore cita l'interferenza da macrotroponina I, nonostante segnalazioni in letteratura.","Tutti i produttori valutano le interferenze da farmaci, ma in modo del tutto disomogeneo: numero di farmaci testati variabile da 22 a 53 (uno dichiara 52 senza elencarli), solo 3 farmaci testati da almeno 4 produttori e 7 da almeno 3, e concentrazioni di riferimento non comparabili tra ditte.","Una premessa rilevante: nella IV Indagine GdS MM (2017) il 64% dei laboratori italiani usa i livelli decisionali (LD) di cTn suggeriti dal produttore (56% nel 2012), mentre la verifica in laboratorio dei LD è scesa al 2,5% (8,3% nel 2012) — segno di crescente dipendenza dall'informazione industriale.","Conclusione: i data sheet forniscono informazioni disomogenee, spesso poco dettagliate e non sufficienti da sole per impostare sistemi di prevenzione/correzione dei FP/FN; vanno integrate con la letteratura scientifica e le Società Scientifiche dovrebbero fornire materiali informativi e raccomandazioni dedicate."],"related":["[[SIPMeL]]","[[Gruppo di Studio sui Marcatori Miocardici (GdS MM) SIPMeL]]","[[SIPMeL - Falsi Positivi e Falsi Negativi di Troponina - Parte I (Revisione Letteratura)]]","[[SIPMeL - Falsi Positivi e Falsi Negativi di Troponina - Parte II (Indagine GdS MM)]]","[[SIPMeL - Falsi Positivi e Falsi Negativi di Troponina - Parte IV (Raccomandazioni GdS MM)]]","[[Troponina Cardiaca ad Alta Sensibilità (hs-cTn)]]","[[Falsi Positivi e Falsi Negativi in Diagnostica di Laboratorio]]","[[Validazione e Verifica dei Metodi Analitici]]","[[ISO 15189]]"]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"key":"Wiki/sources/SIPMeL - Falsi Positivi e Falsi Negativi di Troponina - Parte III (Ruolo Industria).md"},
