808863,-0.01004198,0.03226198,-0.01406336,0.08055612,-0.0151929,-0.00373457,-0.01285852,0.17025852,-0.01857057,-0.02091417,0.01211774,-0.01562777,0.04797727,-0.00899806,0.05469227,0.02081506,-0.01208708,0.13310011,-0.01255567,-0.01693019,0.06082202,-0.06817415,-0.02162969,-0.01336436,0.00089073,-0.05342586,0.01159176,-0.01604634,0.04059826,0.10577181,-0.01196319,-0.03341227,-0.02529543,0.02574248,0.04064675,-0.02498769,0.01323887,-0.01360745,-0.01753473,-0.00686328,-0.00132954,0.05676657,-0.0302985,-0.01178461,-0.01920754,-0.06605072,0.02740517,0.01258072,0.04641094,0.0319473],"last_embed":{"tokens":448,"hash":"1bw9hp1"}}},"last_read":{"hash":"1bw9hp1","at":1781675951131},"class_name":"SmartSource","last_import":{"mtime":1781283510000,"size":4221,"at":1781675837061,"hash":"1bw9hp1"},"blocks":{"#---frontmatter---":[1,35],"##Cosa è":[37,40],"##Cosa è#{1}":[39,40],"##Contenuto principale":[41,48],"##Contenuto principale#{1}":[43,48],"##Collegamento con ISO 15189 e l'accreditamento":[49,52],"##Collegamento con ISO 15189 e l'accreditamento#{1}":[51,52]},"outlinks":[{"title":"Valori Critici","target":"Valori Critici","line":27},{"title":"ISO 15189","target":"ISO 15189","line":28},{"title":"Procedura Operativa Standard ISO 15189 (SOP Master)","target":"Procedura Operativa Standard ISO 15189 (SOP Master)","line":29},{"title":"SOP Tabella Valori Critici (Esempio)","target":"SOP Tabella Valori Critici (Esempio)","line":30},{"title":"ACCREDIA","target":"ACCREDIA","line":31},{"title":"SIPMeL","target":"SIPMeL","line":32},{"title":".raw/Procedura Operativa Standard ISO 15189 - Controllo dei Valori Critici.docx","target":".raw/Procedura Operativa Standard ISO 15189 - Controllo dei Valori Critici.docx","line":34},{"title":"Procedura Operativa Standard ISO 15189 (SOP Master)","target":"Procedura Operativa Standard ISO 15189 (SOP Master)","line":39},{"title":"ACCREDIA","target":"ACCREDIA","line":51},{"title":"ISO 15189","target":"ISO 15189","line":51},{"title":"SIPMeL","target":"SIPMeL","line":51},{"title":"SOP Tabella Valori Critici (Esempio)","target":"SOP Tabella Valori Critici (Esempio)","line":51},{"title":"Valori Critici","target":"Valori Critici","line":51}],"metadata":{"type":"source","title":"SOP Controllo Valori Critici","created":"2026-06-12","updated":"2026-06-12","tags":["#laboratorio-medico","#source","#normativa","#valori-critici"],"status":"developing","address":"c-000017","source_type":"internal-document","author":"","date_published":"2026-06-12","url":"","confidence":"high","key_claims":["SOP-GEN-008 'Procedura per la gestione e comunicazione dei valori critici', Rev. 01 del 12/06/2026, ha lo scopo di identificare, validare e comunicare al medico curante i risultati che indicano un rischio immediato per la vita del paziente, garantendo tracciabilità totale.","Si applica a tutti i campioni biologici processati e a tutto il personale tecnico, biologico e medico coinvolto nella validazione.","Identifica due rischi clinici principali: mancata segnalazione del valore critico da parte dell'analizzatore (mitigata da blocco automatico e allarme non bypassabile sul LIS) ed errato destinatario della comunicazione (mitigata dall'obbligo di Read-Back).","Il flusso operativo prevede: identificazione/verifica tecnica del dato (TSLB), validazione clinica con Delta Check (Validatore biologo/medico), e comunicazione d'urgenza entro 15 minuti dalla validazione.","La comunicazione segue una procedura di Read-Back obbligatoria: il Validatore si identifica, registra le generalità del ricevente e fa ripetere ad alta voce nome paziente e valore comunicato.","Ogni comunicazione viene registrata sul LIS nel modulo digitale MOD-QUAL-012 con data/ora, identità del ricevente, esito del Read-Back e note cliniche.","Cita come riferimenti UNI EN ISO 15189:2024 §7.4.2 (Segnalazione dei risultati), il Regolamento Tecnico ACCREDIA RT-35 e le Linee Guida SIBioC-SIPMeL sull'armonizzazione dei valori critici."],"related":["[[Valori Critici]]","[[ISO 15189]]","[[Procedura Operativa Standard ISO 15189 (SOP Master)]]","[[SOP Tabella Valori Critici (Esempio)]]","[[ACCREDIA]]","[[SIPMeL]]"],"sources":["[[.raw/Procedura Operativa Standard ISO 15189 - Controllo dei Valori Critici.docx]]"]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"key":"Wiki/sources/SOP Controllo Valori Critici.md"},
