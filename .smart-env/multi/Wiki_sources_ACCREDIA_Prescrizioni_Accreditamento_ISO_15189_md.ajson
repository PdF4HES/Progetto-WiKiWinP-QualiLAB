425,0.01994552,0.02524244,-0.0362472,0.04863701,0.02358359,-0.00648849,0.04552945,-0.05888638,-0.04492947,-0.02695318,0.14564343,-0.03478099,-0.05876718,0.07607311,-0.0244758,0.05128311,0.02412033,0.02019005,-0.0243745,-0.0326809,0.14157549,0.00007312,-0.01961197,-0.00107639,-0.02350735,0.03892985,0.03632741,-0.04437612,-0.11219596,-0.02196809,-0.02994076,-0.00423413,0.08563134,-0.01974066,-0.06485387,-0.03570518,0.02520992,0.0616353,-0.0112397,-0.03370872,-0.02904342,0.00159557,-0.00071272,0.00805224,0.01401467,0.01361216,0.01887191,0.00241518,-0.0243607,0.00753402,-0.01120041,0.04217609,0.03152146],"last_embed":{"tokens":458,"hash":"ed5swm"}}},"last_read":{"hash":"ed5swm","at":1781675929730},"class_name":"SmartSource","last_import":{"mtime":1781282472000,"size":4595,"at":1781675837061,"hash":"ed5swm"},"blocks":{"#---frontmatter---":[1,28],"##Cosa è":[30,33],"##Cosa è#{1}":[32,33],"##Struttura e contenuti principali":[34,46],"##Struttura e contenuti principali#{1}":[36,37],"##Struttura e contenuti principali#{2}":[38,38],"##Struttura e contenuti principali#{3}":[39,39],"##Struttura e contenuti principali#{4}":[40,40],"##Struttura e contenuti principali#{5}":[41,41],"##Struttura e contenuti principali#{6}":[42,42],"##Struttura e contenuti principali#{7}":[43,43],"##Struttura e contenuti principali#{8}":[44,44],"##Struttura e contenuti principali#{9}":[45,46],"##Relazioni":[47,50],"##Relazioni#{1}":[49,50]},"outlinks":[{"title":"ACCREDIA","target":"ACCREDIA","line":32},{"title":"UNI EN ISO 15189:2024","target":"ISO 15189","line":32},{"title":"Processo di Accreditamento","target":"Processo di Accreditamento","line":49},{"title":"SIPMeL","target":"SIPMeL","line":49}],"metadata":{"type":"source","title":"ACCREDIA - Prescrizioni per l'accreditamento ISO 15189 dei laboratori","created":"2026-06-12","updated":"2026-06-12","tags":["#laboratorio-medico","#source","#accreditamento","#iso-15189","#accredia"],"status":"developing","address":"c-000006","source_type":"regulation","author":"ACCREDIA - Dipartimento Laboratori di Prova","date_published":"2024-12-17","url":"","confidence":"high","key_claims":["Il documento (sigla RT-35, rev. 03, in vigore dal 01-07-2025) traduce i requisiti della UNI EN ISO 15189:2024 in prescrizioni operative ACCREDIA, seguendo la stessa numerazione dei paragrafi della norma.","Definisce 'metodo interno' (incluse modifiche/assemblaggi di IVD e usi RUO a scopo diagnostico) e 'metodo di esame IVD', distinzione cruciale per gli obblighi di validazione.","L'accreditamento riguarda solo attività eseguite in proprio dal laboratorio; l'affidamento continuativo all'esterno è escluso dal campo di accreditamento.","Il prelievo campioni (anche a domicilio o su autoemoteca) è accreditabile se sotto responsabilità del laboratorio richiedente e finalizzato a esami accreditati; non è accreditabile la raccolta per trasfusione.","I POCT (point-of-care testing) possono entrare nel campo di accreditamento solo se il laboratorio garantisce i requisiti applicabili di ISO 15189 e dell'Allegato A del documento.","Dettaglia la politica di riferibilità metrologica (ILAC P10): tarature tramite NMI/CIPM-MRA o laboratori accreditati EA-MLA/ILAC-MRA come prima scelta; tarature interne ammesse a condizioni precise.","I metodi interni con campo fisso devono essere inviati ad ACCREDIA con dichiarazione di validazione; senza tale invio gli esami sono esclusi dall'accreditamento.","Per VEQ (valutazione esterna di qualità), registrazioni minime 48 mesi (o termine di legge se superiore); l'uso del marchio ACCREDIA sui rapporti è regolato da RG-09."]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"key":"Wiki/sources/ACCREDIA Prescrizioni Accreditamento ISO 15189.md"},
