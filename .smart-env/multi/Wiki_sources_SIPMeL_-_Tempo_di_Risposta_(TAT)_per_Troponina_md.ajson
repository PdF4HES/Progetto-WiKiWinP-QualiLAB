47,0.03691015,0.02925039,0.0449276,-0.01804287,0.00087069,0.00909037,-0.03225639,0.00893639,-0.03023086,-0.01500564,0.04343756,0.17531209,-0.02707527,-0.0433565,0.0602672,-0.02416506,0.06061526,0.07565319,0.01426184,-0.00437268,0.00553126,0.13605641,-0.01882277,-0.00424486,0.06107624,-0.02839547,0.04671336,-0.06087333,0.01659493,-0.02206692,-0.01908665,-0.02960699,0.00160316,0.07397918,-0.06300566,-0.05184847,-0.06977898,-0.01115332,0.06314837,-0.03335265,-0.03911437,-0.00600377,0.01878982,-0.00207213,0.03421007,0.00040032,-0.0047567,-0.03225618,-0.02794594,-0.01777045,-0.03113944,-0.03056791,0.07768927,0.01548997],"last_embed":{"tokens":450,"hash":"1xvoomm"}}},"last_read":{"hash":"1xvoomm","at":1781675962316},"class_name":"SmartSource","last_import":{"mtime":1781297520000,"size":4822,"at":1781675837115,"hash":"1xvoomm"},"blocks":{"#---frontmatter---":[1,49],"#":[51,53],"##Sintesi":[54,59],"##Sintesi#{1}":[56,59],"##Evoluzione del quadro: dal 2012 al 2018":[60,63],"##Evoluzione del quadro: dal 2012 al 2018#{1}":[62,63],"##Implicazioni organizzative":[64,67],"##Implicazioni organizzative#{1}":[66,67]},"outlinks":[{"title":"SIPMeL","target":"SIPMeL","line":35},{"title":"Gruppo di Studio sui Marcatori Miocardici (GdS MM) SIPMeL","target":"Gruppo di Studio sui Marcatori Miocardici (GdS MM) SIPMeL","line":36},{"title":"Troponina Cardiaca ad Alta Sensibilità (hs-cTn)","target":"Troponina Cardiaca ad Alta Sensibilità (hs-cTn)","line":37},{"title":"Turnaround Time (TAT) in Laboratorio","target":"Turnaround Time (TAT) in Laboratorio","line":38},{"title":"Point-of-Care Testing (POCT)","target":"Point-of-Care Testing (POCT)","line":39},{"title":"ISO 15189","target":"ISO 15189","line":40},{"title":"SIPMeL - Tempo di Risposta (TAT) per Troponina - Aggiornamento 2024","target":"SIPMeL - Tempo di Risposta (TAT) per Troponina - Aggiornamento 2024","line":52},{"title":"Gruppo di Studio sui Marcatori Miocardici (GdS MM) SIPMeL","target":"Gruppo di Studio sui Marcatori Miocardici (GdS MM) SIPMeL","line":56},{"title":"SIPMeL","target":"SIPMeL","line":56},{"title":"Troponina Cardiaca ad Alta Sensibilità (hs-cTn)","target":"Troponina Cardiaca ad Alta Sensibilità (hs-cTn)","line":62},{"title":"ISO 15189","target":"ISO 15189","line":66},{"title":"Point-of-Care Testing (POCT)","target":"Point-of-Care Testing (POCT)","line":66},{"title":"Sistema Informativo di Laboratorio (LIS)","target":"Sistema Informativo di Laboratorio (LIS)","line":66}],"metadata":{"type":"source","title":"SIPMeL - Tempo di Risposta (TAT) per Troponina","created":"2026-06-12","updated":"2026-06-12","tags":["#laboratorio-medico","#source","#troponina","#tat","#sipmel"],"status":"developing","address":"c-000058","source_type":"raccomandazione","year":2018,"authors":["Daniela Rubin","Matteo Cassin","Margherita Morandini","Piero Cappelletti","Francesca Veneziani","Maria Aurora Burgio","Massimiliano Manno","Elisabetta Stenner","Marco Moretti","Giulio Marino","Dina Di Maria","Deborah Mazzei","Lucia Malloggi","Alessio Gamboni","Gianni Antonio Galli"],"publication":"Riv Ital Med Lab (2018) 14:105–121","doi":"10.1007/s13631-018-0192-z","related":["[[SIPMeL]]","[[Gruppo di Studio sui Marcatori Miocardici (GdS MM) SIPMeL]]","[[Troponina Cardiaca ad Alta Sensibilità (hs-cTn)]]","[[Turnaround Time (TAT) in Laboratorio]]","[[Point-of-Care Testing (POCT)]]","[[ISO 15189]]"],"key_claims":["Tre linee guida cliniche su otto e cinque linee guida di laboratorio su cinque, pubblicate dopo il 2012, convergono nell'indicare un TAT di cTn ≤ 1 ora (60 minuti).","La linea guida ESC 2015 per le SCA senza sopraslivellamento ST raccomanda (Classe I, Livello A) di misurare la cTn con metodi sensibili o ad alta sensibilità e ottenere il risultato entro 60 minuti.","Gli algoritmi diagnostici rapidi con hs-cTn (T0, 30 min, 0/1h, 0/2h, 0/3h) permettono una decisione clinica entro 1 ora per oltre due terzi e a T0 per oltre un terzo dei pazienti DE con sospetto NSTEMI, con NPV per eventi avversi rispettivamente 98,7–100% e 95,5–100%.","Esiste discrepanza nella definizione del punto di partenza del TAT: alcune linee guida lo misurano dal prelievo (sampling-to-report), altre dalla ricezione del campione in laboratorio (receipt-to-report).","La Raccomandazione 11 del precedente lavoro GdS MM SIPMeL sul POCT di cTn (2016) fissa il TAT, dal prelievo alla consegna della risposta, in 1 ora (obiettivo massimo) e 30 minuti (obiettivo ottimale), da concordare con i clinici (Classe I, Livello B).","La fase pre-analitica è storicamente considerata la più critica per il TAT totale, ma la letteratura più recente (2013-2018) ne discute l'effettivo peso rispetto alle fasi analitica e post-analitica.","Conclusione: il TAT di hs-cTn deve essere inferiore a 1 ora, misurato dal momento del prelievo, per supportare adeguatamente gli algoritmi diagnostici rapidi raccomandati dalle linee guida cliniche."]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"key":"Wiki/sources/SIPMeL - Tempo di Risposta (TAT) per Troponina.md"},
